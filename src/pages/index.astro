---
import '../styles/global.css';
import AuthModal from '../components/AuthModal.astro';
import ProfileModal from '../components/ProfileModal.astro';
import Sidebar from '../components/Sidebar.astro';
---

<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DojoHub</title>
</head>

<body>

  <header class="topbar">
    <div class="container">
      <div class="topbar-left">
        <button id="hamburger-btn" class="hamburger" aria-label="Menú">☰</button>
        <div class="logo">
          <a href="/dojohub/" style="text-decoration: none; color: inherit;">
            <span class="dojo">Dojo</span><span class="hub">hub</span>
          </a>
        </div>
      </div>

      <div class="search">
        <span class="search-icon">🔍</span>
        <input type="text" id="search-input" placeholder="Buscar combos...">
      </div>

      <div class="topbar-right">
        <div class="user-menu-container">
          <span id="display-username" class="username-tag"></span>
          <button id="user-btn" class="user-icon" aria-label="Usuario">
            <img src="https://cdn.pixabay.com/photo/2023/02/18/11/00/icon-7797704_640.png" alt="Avatar" class="user-avatar-img" onerror="this.src='https://cdn.pixabay.com/photo/2023/02/18/11/00/icon-7797704_640.png'">
          </button>
          
          <div id="user-dropdown" class="dropdown-menu">
            <button id="btn-edit-profile" class="dropdown-item">⚙️ Editar Perfil</button>
            <button id="btn-logout" class="dropdown-item logout">🚪 Cerrar Sesión</button>
          </div>
        </div>
      </div>
    </div>
  </header>

  <nav class="menu">
    <div class="container">
      <a href="#" class="active" data-filter="all">Inicio</a>
      <a href="#" data-filter="#xbox">XBOX</a>
      <a href="#" data-filter="#teclado">Keyboard</a>
      <a href="#" data-filter="#playstation">PlayStation</a>
      <a href="#" data-filter="#android">Android</a>
    </div>
  </nav>

  <main class="content">
    <div class="container">
      <div class="grid" id="combo-grid">
        <!-- Los combos se cargarán dinámicamente desde Supabase -->
        <p class="loading-message">Cargando la sabiduría del Dojo...</p>
      </div>
      <div id="pagination" class="pagination"></div>

      <footer class="site-footer">
        <div class="footer-widget">
          <h3>Descarga DojoInputs</h3>
          <div class="itch-embed">
            <iframe frameborder="0" src="https://itch.io/embed/4209052?dark=true" width="552" height="167">
              <a href="https://geraldglitch.itch.io/dojoinputs">DojoInputs by Gerald Glitch</a>
            </iframe>
          </div>
        </div>
        <p class="footer-copy">© 2026 DojoHub — Desarrollado por GeraldGlitch para la comunidad</p>
      </footer>
    </div>
  </main>

  <div id="video-modal" class="modal">
    <div class="modal-content">
      <button class="modal-close" id="modal-close">&times;</button>
      <iframe id="video-iframe" src="" allowfullscreen></iframe>
    </div>
  </div>

  <AuthModal />
  <ProfileModal />
  <Sidebar />

  <script>
    import { supabase } from '../lib/supabase';
    
    // Test Supabase connection (optional/silent for now)
    // console.log('Supabase initialized:', supabase);

    const ITEMS_PER_PAGE = 9;
    const grid = document.getElementById('combo-grid');
    const paginationContainer = document.getElementById('pagination');
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const filterLinks = document.querySelectorAll('.menu a[data-filter]');
    // Referencias para Auth y Perfil
    const userBtn = document.getElementById('user-btn');
    const userDropdown = document.getElementById('user-dropdown');
    const btnEditProfile = document.getElementById('btn-edit-profile');
    const btnLogout = document.getElementById('btn-logout');

    const hamburgerBtn = document.getElementById('hamburger-btn');
    const sidebar = document.getElementById('sidebar');
    const sidebarOverlay = document.getElementById('sidebar-overlay');
    const sidebarClose = document.getElementById('sidebar-close');

    const authModal = document.getElementById('auth-modal');
    const authModalClose = document.getElementById('auth-modal-close');
    const authForm = document.getElementById('auth-form');
    const authStatus = document.getElementById('auth-status');
    const tabLogin = document.getElementById('tab-login');
    const tabRegister = document.getElementById('tab-register');
    const authTitle = document.getElementById('auth-title');
    const authSubmitBtn = document.getElementById('auth-submit-btn');

    const profileModal = document.getElementById('profile-modal');
    const profileModalClose = document.getElementById('profile-modal-close');
    const profileForm = document.getElementById('profile-form');
    const profileStatus = document.getElementById('profile-status');

    const displayUsername = document.getElementById('display-username');
    const videoModal = document.getElementById('video-modal');
    const videoIframe = document.getElementById('video-iframe') as HTMLIFrameElement;
    const videoCloseBtn = document.getElementById('modal-close');

    // Estado Global
    let allCombosData: any[] = [];
    let filteredCombosData: any[] = [];
    let profileMap: Record<string, any> = {};
    let activeFilter = 'all';
    let currentPage = 1;

    let authMode = 'login'; 

    // Inicialización del Usuario y Avatar
    async function initUser() {
      const { data: { user } } = await supabase.auth.getUser();
      if (user) {
        const { data: profile } = await supabase
          .from('profiles')
          .select('username, rango, avatar_url')
          .eq('id', user.id)
          .single();
        
        if (displayUsername) {
          displayUsername.textContent = profile?.username || user.email?.split('@')[0];
        }

        if (profile?.avatar_url) {
          const avatarImgs = document.querySelectorAll('.user-avatar-img');
          avatarImgs.forEach(img => { (img as HTMLImageElement).src = profile.avatar_url; });
        }
      }
    }

    // Cargar Datos Iniciales
    async function loadCombos() {
      if (!grid) return;
      
      const { data: combos, error } = await supabase
        .from('combos')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) {
        grid.innerHTML = '<p class="error-message">Error al conectar con el Dojo. Revisa la consola.</p>';
        return;
      }

      if (!combos || combos.length === 0) {
        grid.innerHTML = '<p class="empty-message">El Dojo está vacío. ¡Sé el primero en subir un combo!</p>';
        return;
      }

      // Obtener perfiles para los autores
      const userIds = [...new Set(combos.map(c => c.user_id))];
      const { data: profiles } = await supabase
        .from('profiles')
        .select('id, username, rango')
        .in('id', userIds);

      profileMap = {};
      (profiles || []).forEach(p => { profileMap[p.id] = p; });

      allCombosData = combos;
      applyFilters();
    }

    // Lógica de Filtrado y Búsqueda
    function applyFilters() {
      const query = searchInput?.value.toLowerCase().trim() || '';
      
      filteredCombosData = allCombosData.filter(combo => {
        const matchesFilter = activeFilter === 'all' || (combo.combo_tags && combo.combo_tags.includes(activeFilter));
        const matchesSearch = !query || 
          combo.name.toLowerCase().includes(query) || 
          (combo.description && combo.description.toLowerCase().includes(query)) ||
          (profileMap[combo.user_id]?.username || '').toLowerCase().includes(query);

        return matchesFilter && matchesSearch;
      });

      renderGrid(1);
    }

    // Renderizado de Grid
    const rankColors: Record<string, string> = {
      'Tin': '#4dff88', 'Bronce': '#cd7f32', 'Plata': '#c0c0c0',
      'Oro': '#ffd700', 'Platino': '#00bfff', 'Diamante': '#9b4dff',
      'Vallhalan': '#ff4db8'
    };

    function renderGrid(page: number) {
      if (!grid) return;
      currentPage = page;
      grid.innerHTML = '';

      if (filteredCombosData.length === 0) {
        grid.innerHTML = '<p class="empty-message">No se encontraron técnicas con esos criterios.</p>';
        renderPagination();
        return;
      }

      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = start + ITEMS_PER_PAGE;
      const pageItems = filteredCombosData.slice(start, end);

      pageItems.forEach(combo => {
        const profile = profileMap[combo.user_id];
        const rankColor = rankColors[profile?.rango] || '#888';
        const username = profile?.username || 'Sensei Desconocido';

        const card = document.createElement('div');
        card.className = 'card';
        card.setAttribute('data-id', combo.id);

        card.innerHTML = `
          <div class="card-media">
            <img src="${combo.image_url}" alt="${combo.name}" onerror="this.src='/dojohub/images/sample.png'">
            ${combo.video_url ? `<button class="btn-video" data-video="${combo.video_url}">🎬 Ver Video</button>` : ''}
          </div>
          <div class="card-details">
            <div class="author-info">
              <span class="author-name">${username}</span>
              <span class="rank-circle" style="background: ${rankColor}"></span>
              <div class="meta-right">
                <span class="eye-icon">👁️</span>
                <span class="download-count">${combo.downloads_count || 0}</span>
              </div>
            </div>
            <p class="filename">
              <a href="${combo.json_data_url}" download="${combo.name}.dojofiles">
                ${combo.name}.dojofiles
              </a>
            </p>
          </div>
        `;
        grid.appendChild(card);
      });

      renderPagination();
    }

    // Renderizado de Paginación
    function renderPagination() {
      if (!paginationContainer) return;
      paginationContainer.innerHTML = '';
      const totalPages = Math.ceil(filteredCombosData.length / ITEMS_PER_PAGE);

      if (totalPages <= 1) return;

      const createBtn = (text: string | number, page: number, active = false, disabled = false, className = '') => {
        const btn = document.createElement('button');
        btn.textContent = String(text);
        if (active) btn.classList.add('active');
        if (className) btn.classList.add(className);
        btn.disabled = disabled;
        btn.addEventListener('click', () => {
          renderGrid(page);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        return btn;
      };

      paginationContainer.appendChild(createBtn('<', currentPage - 1, false, currentPage === 1, 'prev'));

      for (let i = 1; i <= totalPages; i++) {
        paginationContainer.appendChild(createBtn(i, i, i === currentPage));
      }

      paginationContainer.appendChild(createBtn('>', currentPage + 1, false, currentPage === totalPages, 'next'));
    }

    // Event Listeners: Filtros y Búsqueda
    filterLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        filterLinks.forEach(l => l.classList.remove('active'));
        link.classList.add('active');
        activeFilter = link.getAttribute('data-filter') || 'all';
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', applyFilters);

    // Event Listeners: Descargas y Video
    grid?.addEventListener('click', async (e: any) => {
      const downloadBtn = e.target.closest('.filename a');
      if (downloadBtn) {
        const comboId = downloadBtn.closest('.card')?.getAttribute('data-id');
        if (comboId) await supabase.rpc('increment_downloads', { combo_id: comboId });
      }

      const videoBtn = e.target.closest('.btn-video');
      if (videoBtn) {
        const videoId = videoBtn.getAttribute('data-video');
        if (videoId && videoIframe && videoModal) {
          videoIframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
          videoModal.classList.add('active');
        }
      }
    });

    videoCloseBtn?.addEventListener('click', () => {
      if (videoModal) videoModal.classList.remove('active');
      if (videoIframe) videoIframe.src = '';
    });

    // Cerrar modal al clickear fuera
    window.addEventListener('click', (e) => {
      if (e.target === videoModal) {
        videoModal.classList.remove('active');
        videoIframe.src = '';
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && videoModal && videoModal.classList.contains('active')) {
        videoModal.classList.remove('active');
        videoIframe.src = '';
      }
    });

    // Sidebar functionality
    function toggleSidebar() {
      sidebar?.classList.toggle('active');
      sidebarOverlay?.classList.toggle('active');
    }

    hamburgerBtn?.addEventListener('click', toggleSidebar);
    sidebarOverlay?.addEventListener('click', toggleSidebar);
    sidebarClose?.addEventListener('click', toggleSidebar);

    // Auth Modal functionality
    if (userBtn) {
      userBtn.addEventListener('click', async () => {
        const { data: { user } } = await supabase.auth.getUser();
        if (user) {
          userDropdown?.classList.toggle('active');
        } else {
          authModal?.classList.add('active');
        }
      });
    }

    // Close dropdown when clicking outside
    window.addEventListener('click', (e) => {
      if (userDropdown?.classList.contains('active') && !userBtn?.contains(e.target as Node)) {
        userDropdown.classList.remove('active');
      }
    });

    if (btnLogout) {
      btnLogout.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = '/dojohub/';
      });
    }

    if (btnEditProfile) {
      btnEditProfile.addEventListener('click', async () => {
        userDropdown?.classList.remove('active');
        const { data: { user } } = await supabase.auth.getUser();
        if (user) {
          // Pre-cargar datos del perfil
          const { data: profile } = await supabase
            .from('profiles')
            .select('*')
            .eq('id', user.id)
            .single();

          const usernameInput = document.getElementById('profile-username') as HTMLInputElement;
          const emailInput = document.getElementById('profile-email') as HTMLInputElement;
          const rangoSelect = document.getElementById('profile-rango') as HTMLSelectElement;
          const avatarInput = document.getElementById('profile-avatar') as HTMLInputElement;

          if (usernameInput) usernameInput.value = profile?.username || '';
          if (emailInput) emailInput.value = user.email || '';
          if (rangoSelect) rangoSelect.value = profile?.rango || 'Tin';
          if (avatarInput) avatarInput.value = profile?.avatar_url || '';

          profileModal?.classList.add('active');
        }
      });
    }

    if (profileModalClose) {
      profileModalClose.addEventListener('click', () => profileModal?.classList.remove('active'));
    }

    if (profileForm) {
      profileForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const username = (document.getElementById('profile-username') as HTMLInputElement).value;
        const rango = (document.getElementById('profile-rango') as HTMLSelectElement).value;
        const avatar_url = (document.getElementById('profile-avatar') as HTMLInputElement).value;
        const newPassword = (document.getElementById('profile-new-password') as HTMLInputElement).value;

        if (profileStatus) {
          profileStatus.textContent = 'Guardando...';
          profileStatus.className = 'status-message';
        }

        const { data: { user } } = await supabase.auth.getUser();
        if (!user) return;

        // 1. Actualizar perfil en la tabla
        const { error: profileError } = await supabase
          .from('profiles')
          .update({ 
            username, 
            rango, 
            avatar_url,
            updated_at: new Date() 
          })
          .eq('id', user.id);

        if (profileError) {
          if (profileStatus) {
            profileStatus.textContent = profileError.message;
            profileStatus.classList.add('error');
          }
          return;
        }

        // 2. Actualizar contraseña si se proporcionó
        if (newPassword) {
          const { error: pwdError } = await supabase.auth.updateUser({ password: newPassword });
          if (pwdError) {
            if (profileStatus) {
              profileStatus.textContent = 'Perfil guardado, pero error en contraseña: ' + pwdError.message;
              profileStatus.classList.add('error');
            }
            return;
          }
        }

        if (profileStatus) {
          profileStatus.textContent = '¡Perfil actualizado!';
          profileStatus.classList.add('success');
        }
        setTimeout(() => window.location.href = '/dojohub/', 1500);
      });
    }

    if (authModalClose) {
      authModalClose.addEventListener('click', () => authModal?.classList.remove('active'));
    }

    if (tabLogin && tabRegister) {
      tabLogin.addEventListener('click', () => setAuthMode('login'));
      tabRegister.addEventListener('click', () => setAuthMode('register'));
    }

    function setAuthMode(mode) {
      authMode = mode;
      tabLogin?.classList.toggle('active', mode === 'login');
      tabRegister?.classList.toggle('active', mode === 'register');
      if (authTitle) authTitle.textContent = mode === 'login' ? 'Dojo Login' : 'Unete al Dojo';
      if (authSubmitBtn) authSubmitBtn.textContent = mode === 'login' ? 'Entrar' : 'Crear Cuenta';
    }

    if (authForm) {
      authForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = (document.getElementById('auth-email') as HTMLInputElement).value;
        const password = (document.getElementById('auth-password') as HTMLInputElement).value;
        
        if (authStatus) {
            authStatus.textContent = 'Procesando...';
            authStatus.className = 'auth-status';
        }

        let result;
        if (authMode === 'login') {
          result = await supabase.auth.signInWithPassword({ email, password });
        } else {
          result = await supabase.auth.signUp({ email, password });
        }

        if (result.error) {
          if (authStatus) {
            authStatus.textContent = result.error.message;
            authStatus.classList.add('error');
          }
        } else {
          if (authStatus) {
            authStatus.textContent = authMode === 'login' ? '¡Bienvenido Sensei!' : '¡Cuenta creada! Revisa tu email.';
            authStatus.classList.add('success');
          }
          setTimeout(() => window.location.href = '/dojohub/', 1500);
        }
      });
    }

    // Iniciar el Dojo
    initUser();
    loadCombos();
  </script>

</body>

</html>
