---
---
<div id="auth-modal" class="modal">
  <div class="modal-content auth-content">
    <button class="modal-close" id="auth-modal-close" aria-label="Cerrar">&times;</button>
    <div class="auth-tabs">
      <button id="tab-login" class="tab-btn active" data-mode="login">Entrar</button>
      <button id="tab-register" class="tab-btn" data-mode="register">Unirse</button>
    </div>
    
    <div class="auth-header">
      <h2 id="auth-title">Dojo Login</h2>
      <p id="auth-subtitle">Registra tu entrenamiento hoy</p>
    </div>

    <form id="auth-form" class="auth-form">
      <div class="form-group">
        <label for="auth-email">Email</label>
        <input type="email" id="auth-email" required placeholder="Sensei@dojohub.com">
      </div>
      <div class="form-group">
        <label for="auth-password">Contraseña</label>
        <input type="password" id="auth-password" required minlength="6" placeholder="••••••••">
      </div>
      <button type="submit" id="auth-submit-btn" class="btn-primary">Aceptar</button>
      <p id="auth-status" class="auth-status"></p>
    </form>
  </div>
</div>

<style>
  .auth-tabs {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .tab-btn {
    padding: 0.5rem 1rem;
    background: transparent;
    border: none;
    color: var(--text-muted, #888);
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.2s;
    border-bottom: 2px solid transparent;
  }

  .tab-btn.active {
    color: var(--accent-color, #ff4d4d);
    border-bottom-color: var(--accent-color, #ff4d4d);
  }

  .auth-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .auth-header h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .auth-header p {
    color: #888;
    font-size: 0.9rem;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.85rem;
    color: #ccc;
  }

  .form-group input {
    padding: 0.8rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    outline: none;
    transition: border-color 0.2s;
  }

  .form-group input:focus {
    border-color: #ff4d4d;
  }

  .btn-primary {
    padding: 1rem;
    border-radius: 8px;
    background: #ff4d4d;
    color: white;
    border: none;
    font-weight: bold;
    cursor: pointer;
    transition: transform 0.2s, background 0.2s;
  }

  .btn-primary:hover {
    background: #ff6666;
    transform: translateY(-2px);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .auth-status {
    font-size: 0.85rem;
    text-align: center;
    min-height: 1.2rem;
  }

  .auth-status.error {
    color: #ff4d4d;
  }

  .auth-status.success {
    color: #4dff88;
  }
</style>
